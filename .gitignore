# ==========================================
# ENVIRONMENT VARIABLES & SECRETS
# ==========================================
.env
.env.local
.env.*.local
# Note: If you explicitly want to commit .env.production for Vercel/Netlify, 
# you can uncomment the next line to force Git to track it:
# !.env.production

# ==========================================
# FRONTEND (Node.js, Vite, React)
# ==========================================
node_modules/
dist/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# BACKEND (Java, Spring Boot, Maven)
# ==========================================
target/
build/
*.class
*.jar
*.war
*.pom

# Maven-specific files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
.flattened-pom.xml

# ==========================================
# LOG FILES
# ==========================================
*.log

# ==========================================
